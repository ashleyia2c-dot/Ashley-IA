{
  "name": "ashley",
  "version": "0.9.3",
  "description": "Ashley - Personal AI Companion",
  "main": "main.js",
  "author": "Mister Squishi",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "release": "electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.ashley.companion",
    "productName": "Ashley",
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "updater.js",
      "onboarding.html",
      "package.json",
      "build-resources/icon.ico"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "ashleyia2c-dot",
        "repo": "Ashley-IA"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-resources/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ashley",
      "runAfterFinish": true,
      "installerIcon": "build-resources/icon.ico",
      "uninstallerIcon": "build-resources/icon.ico",
      "uninstallDisplayName": "Ashley",
      "artifactName": "Ashley-Setup-${version}.${ext}"
    }
  }
}
