# Copia este archivo a `.env` y rellena con tus claves reales.
# `.env` está en .gitignore — nunca se sube al repo.

# xAI Grok API — imprescindible para que Ashley funcione en desarrollo.
# En producción (Electron) el usuario mete su propia clave vía la UI y se
# guarda encriptada con DPAPI; esta variable sólo la necesitás para dev.
# Consíguela en https://x.ai/
XAI_API_KEY=xai-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
